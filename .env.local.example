# ─────────────────────────────────────────────────────────────────────────────
# Hootling — Environment Variables
# Copy this file to .env.local and fill in all values before running the app.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Maps ───────────────────────────────────────────────────────────────
# Used client-side for Places Autocomplete (NEXT_PUBLIC_) and server-side for
# Distance Matrix + Directions (non-public key, no referrer restriction needed).
#
# ⚠️  MANDATORY BEFORE LAUNCH — restrict the PUBLIC key in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
#   1. Application restrictions → HTTP referrers
#      Add: https://hootling.com/*  and  https://www.hootling.com/*
#      (also add your staging domain, e.g. https://*.vercel.app/* for previews)
#   2. API restrictions → Restrict key to:
#        • Maps JavaScript API
#        • Places API
#      (Distance Matrix + Directions should use the server-side key below)
#
# The server-side key should be restricted to:
#   Application restrictions → IP addresses → your Vercel egress IPs
#   API restrictions → Distance Matrix API, Directions API
#
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_CLIENT_SIDE_KEY_HERE
GOOGLE_MAPS_API_KEY=YOUR_SERVER_SIDE_KEY_HERE

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Used server-side only. Never expose this in NEXT_PUBLIC_ variables.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key: Dashboard → Developers → API keys → Secret key
# Publishable key: Dashboard → Developers → API keys → Publishable key
# Webhook secret: Dashboard → Developers → Webhooks → signing secret
#   Local: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── JWT entitlements ──────────────────────────────────────────────────────────
# Random 32+ character secret used to sign/verify payment entitlement JWTs.
# Generate with: openssl rand -base64 32
ENTITLEMENT_SECRET=

# ── App URL ───────────────────────────────────────────────────────────────────
# Full origin URL — used for canonical links, OG images, CORS headers.
# No trailing slash. Must match your Stripe success_url domain.
NEXT_PUBLIC_APP_URL=https://hootling.com

# ── Vercel KV (optional — Redis-backed cache + rate limiting) ─────────────────
# Set these to enable persistent AI response caching and distributed rate limiting.
# Leave blank for local dev — the app degrades gracefully without KV.
# Dashboard: https://vercel.com/dashboard/stores
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Email (Resend — optional) ─────────────────────────────────────────────────
# Used for the post-purchase email subscription on the success page.
# Leave blank to disable email capture (no error thrown).
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=

# ── Google Analytics 4 (optional) ─────────────────────────────────────────────
# ⚠️  GDPR NOTE: GA4 in standard mode sets _ga / _ga_XXXX cookies.
# Hootling configures GA4 in cookieless mode (client_storage: 'none') in layout.tsx,
# which disables cookie writes while still sending page-view events.
# If you set this ID, no cookie consent banner is required under the current config.
# If you change the gtag() config to re-enable cookies, a consent banner IS required.
# https://analytics.google.com
NEXT_PUBLIC_GA4_ID=

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Error monitoring. Set via `npx @sentry/wizard@latest -i nextjs` or manually.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Protects GET /api/admin/stats. Pass as x-admin-secret header.
# Generate with: openssl rand -hex 24
ADMIN_SECRET=
