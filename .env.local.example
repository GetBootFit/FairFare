# ─────────────────────────────────────────────────────────
# Google Maps Platform
# Requires: Distance Matrix API, Directions API, Places API
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────
# Anthropic / Claude API
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────
# Stripe
# Use test keys (sk_test_...) during development
# ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────
# Entitlement Token Secret
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────
ENTITLEMENT_SECRET=

# ─────────────────────────────────────────────────────────
# App URL (no trailing slash)
# Development: http://localhost:3000
# Production: https://your-app.vercel.app
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────
# Vercel KV (optional — Redis for persistent AI cache + JWT replay prevention)
# Add via: vercel env add KV_REST_API_URL / vercel env add KV_REST_API_TOKEN
# Or create a KV store in the Vercel dashboard and link the project.
# Leave blank for local dev (app degrades gracefully to in-memory cache).
# ─────────────────────────────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=
